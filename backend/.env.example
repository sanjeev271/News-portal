PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/newsportal

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# Comma-separated frontend URLs (required in production)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# HTTPS redirect when behind nginx/load balancer (production)
# FORCE_HTTPS=true

# Upload limits
MAX_FILE_SIZE_MB=10

# Rate limits (requests per window)
# RATE_LIMIT_API=300
# RATE_LIMIT_AUTH=20
# Upload writes only (POST/PUT with files) — not article reads
# RATE_LIMIT_UPLOAD=200

# Skip auto news seed in production unless true
# SEED_ON_START=false

# MongoDB Atlas Search (optional — enables fuzzy/full-text via Atlas)
# ATLAS_SEARCH_ENABLED=true
# ATLAS_SEARCH_INDEX=default

# Public site URL for SEO/RSS/sitemap
# SITE_URL=https://yourdomain.com

ADMIN_EMAIL=admin@newsportal.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Admin
